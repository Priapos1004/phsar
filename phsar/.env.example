DB_USER=animeuser
DB_PASSWORD=animepass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=anime_db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=supersecretpassword
SECRET_KEY=supersecretsecretkey
SEARCH_SECRET_KEY=supersecretsearchsecretkey
# Optional: seeded guest account (restricted_user role, read-only)
# GUEST_USERNAME=guest
# GUEST_PASSWORD=guestpassword

# --- docker-compose only (native uvicorn dev uses defaults) -----------------
# CORS origins for the backend. In compose-parity mode the frontend is served
# on :3000; native dev uses :5173 (covered by the backend default).
# CORS_ORIGINS=["http://localhost:3000"]
# Frontend reads at runtime via $env/dynamic/public. Native dev defaults to
# http://localhost:8000.
# PUBLIC_API_BASE_URL=http://localhost:8000
# Surfaced on /health and in the footer; gets baked into both images as a
# build arg when docker-compose builds.
# APP_VERSION=dev

# --- Backups ----------------------------------------------------------------
# Where dumps land. Defaults to ./backups (cwd-relative) so native uvicorn dev
# works without root; the container Dockerfile sets BACKUP_DIR=/backups.
# BACKUP_DIR=./backups
# pg_restore timeout. Raise if the DB grows large enough that restores
# legitimately take > 10 min. A mid-restore kill leaves the DB half-dropped.
# BACKUP_RESTORE_TIMEOUT_SECONDS=600

# --- Content pipeline (jobs + sweeps) ---------------------------------------
# Shared bearer secret for every cron-authed endpoint:
#   POST /admin/backups/auto              (scheduled dump, ad-hoc)
#   POST /admin/jobs/schedule-sweep       (nightly catalog refresh, ad-hoc)
#   POST /admin/jobs/schedule-seasonal    (weekly /seasons/now pickup, ad-hoc)
#   POST /admin/jobs/schedule-nightly     (combined daily entry — recommended)
# Leave empty to disable every cron endpoint (they fail closed).
JOBS_CRON_TOKEN=
# Max queued+running user_scrape jobs per non-system user. Bounds queue
# DEPTH per user, NOT worker concurrency — the worker is still strictly
# sequential because MAL's ~3 req/s rate limit means parallel jobs would
# just fragment bandwidth.
# JOBS_PER_USER_LIMIT=4
# Re-running the same /jobs/scrape query within this window returns 409.
# Failed jobs don't count, so a transient MAL outage doesn't lock a user out.
# JOBS_DEDUPE_HOURS=72
# Bounds the nightly update_sweep batch size (one tier-selected pass).
# JOBS_SWEEP_MAX_PER_RUN=200