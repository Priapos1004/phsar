# Compose-level env for running all three services together via docker-compose.yml.
# For native dev (uvicorn + bun dev), use phsar/.env instead.

# Database (shared by db and backend services)
DB_USER=animeuser
DB_PASSWORD=animepass
DB_NAME=anime_db

# Admin account seeded on first backend start
ADMIN_USERNAME=admin
ADMIN_PASSWORD=supersecretpassword

# Optional guest account (restricted_user role)
# GUEST_USERNAME=guest
# GUEST_PASSWORD=guestpassword

# Backend secrets
SECRET_KEY=supersecretsecretkey
SEARCH_SECRET_KEY=supersecretsearchsecretkey

# CORS origins for the backend. In compose-parity mode the frontend is
# served on :3000, so point to that.
CORS_ORIGINS=["http://localhost:3000"]

# Frontend build args
PUBLIC_API_BASE_URL=http://localhost:8000
APP_VERSION=dev

# Shared secret for the cron-triggered /admin/backups/auto endpoint.
# Leave empty to disable scheduled backups. In production, configure a Coolify
# scheduled task to POST /admin/backups/auto with `Authorization: Bearer $BACKUP_CRON_TOKEN`.
BACKUP_CRON_TOKEN=
